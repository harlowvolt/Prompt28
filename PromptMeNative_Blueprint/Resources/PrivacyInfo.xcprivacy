<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- Prompt28 does not use cross-app advertising or tracking -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No third-party tracking domains -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!--
        Required API access declarations.
        Only categories actually accessed at runtime are listed.
    -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>

        <!-- UserDefaults: @AppStorage for hasAcceptedPrivacy / hasSeenOnboarding;
             PreferencesStore for mode and saveHistory preferences. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1 — Accessing info from the same app that wrote it -->
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- File timestamps: checked during one-time legacy JSON migration
             in HistoryStore.migrateLegacyJSONIfNeeded(). -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1 — File timestamps not exposed to users or sent off-device -->
                <string>C617.1</string>
            </array>
        </dict>

    </array>

    <!--
        Data types collected by Prompt28.
        All data collection purposes are app functionality or anonymous analytics.
        No data is sold or used for cross-app tracking.
    -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>

        <!-- Email address: required for account registration and login -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeEmailAddress</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Name: optionally provided at email signup; returned by Apple/Google OAuth -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeName</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- User-generated content: the spoken or typed prompt idea sent to the
             Prompt28 server for AI processing. Not linked to identity on server. -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherUserContent</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Product interaction: anonymous usage events (e.g. button taps, feature usage)
             sent to Prompt28 analytics. No PII. Not linked to identity. -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeProductInteraction</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
            </array>
        </dict>

    </array>

</dict>
</plist>
